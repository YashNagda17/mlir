// Anonymous enum: implicit 0..N counting.
enum { RED, GREEN, BLUE };

// Named enum, mixing explicit and implicit values:
//   A=1, B=2, C=10, D=11.
enum Letters { A = 1, B, C = 10, D };

// Reference a previously-declared enumerator in an initializer.
enum Aliases { ALPHA = A, BETA, GAMMA = C };

int classify(int color) {
    switch (color) {
        case RED:   return 100;
        case GREEN: return 200;
        case BLUE:  return 300;
        default:    return -1;
    }
}

int main() {
    _tinyc_print(RED);          // 0
    _tinyc_print(GREEN);        // 1
    _tinyc_print(BLUE);         // 2
    _tinyc_print(A);            // 1
    _tinyc_print(B);            // 2
    _tinyc_print(C);            // 10
    _tinyc_print(D);            // 11
    _tinyc_print(ALPHA);        // 1
    _tinyc_print(BETA);         // 2
    _tinyc_print(GAMMA);        // 10
    _tinyc_print(classify(RED));    // 100
    _tinyc_print(classify(GREEN));  // 200
    _tinyc_print(classify(BLUE));   // 300

    // Enumerators are usable in arbitrary integer contexts.
    int x = D + 5;
    _tinyc_print(x);            // 16
    return 0;
}
