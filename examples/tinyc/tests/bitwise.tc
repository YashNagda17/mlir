int main() {
    _tinyc_print(5 & 3);
    _tinyc_print(5 | 2);
    _tinyc_print(5 ^ 3);
    _tinyc_print(~0);
    _tinyc_print(1 << 3);
    _tinyc_print(16 >> 2);
    int x = 12;
    x &= 10;
    _tinyc_print(x);
    x = 1;
    x |= 4;
    _tinyc_print(x);
    x ^= 7;
    _tinyc_print(x);
    x = 1;
    x <<= 4;
    _tinyc_print(x);
    x >>= 2;
    _tinyc_print(x);
    return 0;
}
