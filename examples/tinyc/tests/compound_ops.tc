int main() {
    int x = 10;
    x += 5;
    _tinyc_print(x);
    x -= 2;
    _tinyc_print(x);
    x *= 3;
    _tinyc_print(x);
    x /= 4;
    _tinyc_print(x);
    x %= 5;
    _tinyc_print(x);
    x = 0;
    int i;
    for (i = 0; i < 5; i = i + 1) {
        x += i;
    }
    _tinyc_print(x);
    int j = 0;
    j++;
    j++;
    _tinyc_print(j);
    j--;
    _tinyc_print(j);
    return 0;
}
