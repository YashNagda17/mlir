int counter = 1;
int total;
float pi = 3.0;
char *greeting = "Hi";

int bump() {
    counter = counter + 1;
    return counter;
}

int main() {
    _tinyc_print(greeting);
    _tinyc_print(counter);
    bump();
    bump();
    _tinyc_print(counter);
    total = counter * 10;
    _tinyc_print(total);
    _tinyc_print(pi);
    return 0;
}
