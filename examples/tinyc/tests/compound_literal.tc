struct Point {
    int x;
    int y;
};

int add_pt(struct Point *p) {
    return p->x + p->y;
}

int main() {
    int a;
    long long b;
    struct Point p = (struct Point){3, 4};
    a = (int){42};
    b = (long long){7};
    _tinyc_print(a);
    _tinyc_print(b);
    _tinyc_print(p.x);
    _tinyc_print(p.y);
    _tinyc_print(add_pt(&p));
    return 0;
}
