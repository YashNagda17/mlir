struct Inner {
    int x;
    int y;
};

struct Outer {
    struct Inner i;
    int z;
};

int sum(struct Outer o) {
    return o.i.x + o.i.y + o.z;
}

int sum_via_ptr(struct Outer* o) {
    return o->i.x + o->i.y + o->z;
}

struct Outer make() {
    struct Outer o;
    o.i.x = 1;
    o.i.y = 2;
    o.z = 3;
    return o;
}

int main() {
    struct Outer o;
    o.i.x = 10;
    o.i.y = 20;
    o.z = 30;
    _tinyc_print(o.i.x);
    _tinyc_print(o.i.y);
    _tinyc_print(o.z);
    _tinyc_print(sum(o));
    _tinyc_print(sum_via_ptr(&o));

    struct Outer m;
    m = make();
    _tinyc_print(m.i.x);
    _tinyc_print(m.i.y);
    _tinyc_print(m.z);
    _tinyc_print(sum(m));
    return 0;
}
