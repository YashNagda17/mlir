// Exercise pointer comparisons against null.

struct Box {
    int value;
    struct Box* link;
};

int has_link(struct Box* p) {
    if (p->link == null) {
        return 0;
    }
    return 1;
}

int has_link_ne(struct Box* p) {
    if (p->link != null) {
        return 1;
    }
    return 0;
}

int main() {
    struct Box* a;
    struct Box* b;
    a = (struct Box*)malloc(sizeof(struct Box));
    b = (struct Box*)malloc(sizeof(struct Box));
    a->value = 1; a->link = b;
    b->value = 2; b->link = null;

    _tinyc_print(has_link(a));     // 1
    _tinyc_print(has_link(b));     // 0
    _tinyc_print(has_link_ne(a));  // 1
    _tinyc_print(has_link_ne(b));  // 0

    // Reassign a's link to null and re-check.
    a->link = null;
    _tinyc_print(has_link(a));     // 0

    // Compare two pointers directly.
    struct Box* c;
    c = a;
    if (a == c) { _tinyc_print(42); }       // 42
    if (a != b) { _tinyc_print(99); }       // 99

    free(a); free(b);
    return 0;
}
