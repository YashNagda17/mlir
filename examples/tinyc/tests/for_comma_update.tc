// MRE: C comma operator in for-loop update expression. Comes from:
//   for (int i = 0, j = 0; i < 16; i++, j += 4) { ... }
// in sha256_xform of mlir_wasm_to_macho.c. tinyc's for-step parser
// only accepts a single expression and rejects the comma between
// `i++` and `j += 4`. (Multi-decl in for-init is already supported.)
//
// Expected: clang accepts and prints "0 0\n1 4\n2 8\n3 12\n"; tinyc too.
extern int printf(const char *fmt, ...);

int main() {
    int j = 0;
    for (int i = 0; i < 4; i = i + 1, j = j + 4) {
        printf("%d %d\n", i, j);
    }
    return 0;
}

