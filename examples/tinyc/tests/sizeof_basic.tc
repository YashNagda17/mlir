// Exercise sizeof on basic and composite types.

struct Pair {
    int a;
    int b;
};

struct WithPtr {
    int v;
    struct Pair* p;
};

int main() {
    _tinyc_print(sizeof(int));               // 4
    _tinyc_print(sizeof(float));             // 4
    _tinyc_print(sizeof(struct Pair));       // 8
    _tinyc_print(sizeof(struct WithPtr));    // 16: int(4) + pad(4) + ptr(8)
    return 0;
}
