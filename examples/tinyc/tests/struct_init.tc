// Aggregate initializer for struct locals: positional and designated.

typedef struct Pt {
    int x;
    int y;
    int z;
} Pt;

int main() {
    Pt a = {1, 2, 3};
    Pt b = {.x = 10, .y = 20, .z = 30};
    Pt c = {.z = 700, .x = 100, .y = 400};
    _tinyc_print(a.x); _tinyc_print(a.y); _tinyc_print(a.z);
    _tinyc_print(b.x); _tinyc_print(b.y); _tinyc_print(b.z);
    _tinyc_print(c.x); _tinyc_print(c.y); _tinyc_print(c.z);
    return 0;
}
