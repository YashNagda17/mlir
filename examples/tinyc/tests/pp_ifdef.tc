// Conditional compilation: #ifdef, #ifndef, #else, #endif, #undef,
// #if defined(X), #elif.

#define FEATURE_A
#define VERSION 2

int main() {
#ifdef FEATURE_A
    _tinyc_print(1);            // 1
#else
    _tinyc_print(99);
#endif

#ifndef FEATURE_A
    _tinyc_print(99);
#else
    _tinyc_print(2);            // 2
#endif

#undef FEATURE_A

#ifdef FEATURE_A
    _tinyc_print(99);
#else
    _tinyc_print(3);            // 3
#endif

#if defined(VERSION) && VERSION == 2
    _tinyc_print(4);            // 4
#elif defined(VERSION)
    _tinyc_print(99);
#else
    _tinyc_print(99);
#endif

#if !defined(FEATURE_A)
    _tinyc_print(5);            // 5
#endif

#if VERSION > 5
    _tinyc_print(99);
#elif VERSION > 1
    _tinyc_print(6);            // 6
#else
    _tinyc_print(99);
#endif
    return 0;
}
