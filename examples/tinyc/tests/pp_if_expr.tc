// Constant expression evaluation in #if.

#define X 7

int main() {
#if (3 + 4) * 2 == 14
    _tinyc_print(1);            // 1
#endif

#if X * X - 1 == 48
    _tinyc_print(2);            // 2
#endif

#if (1 << 4) | 2 == 18
    _tinyc_print(3);            // 3
#endif

#if 1 ? 4 : 99
    _tinyc_print(4);            // 4
#endif

#if 0 ? 99 : 5
    _tinyc_print(5);            // 5
#endif

#if (10 % 3) == 1 && (10 / 3) == 3
    _tinyc_print(6);            // 6
#endif

#if !(0)
    _tinyc_print(7);            // 7
#endif

#if ~0 == -1
    _tinyc_print(8);            // 8
#endif

#if defined(X) + defined(Y) == 1
    _tinyc_print(9);            // 9
#endif

    return 0;
}
