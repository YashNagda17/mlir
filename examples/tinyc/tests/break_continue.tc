int main() {
    int s = 0;
    int i = 0;
    while (i < 10) {
        i = i + 1;
        if (i == 4) {
            continue;
        }
        if (i == 7) {
            break;
        }
        s = s + i;
    }
    _tinyc_print(s);    // 1+2+3+5+6 = 17
    _tinyc_print(i);    // 7
    return 0;
}
